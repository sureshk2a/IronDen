# IronDen — Environment Variables
# Copy this file to .env and adjust values for your deployment

# Application database
POSTGRES_DB=ironden
POSTGRES_USER=ironden
POSTGRES_PASSWORD=ironden_pass

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin          # CHANGE IN PRODUCTION

# Backend
SHOW_MOCK_DATA=false          # Set to true to populate dashboard with demo data
DATABASE_URL=postgresql://ironden:ironden_pass@app-db:5432/ironden
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ironden
KEYCLOAK_CLIENT_ID=ironden-app
CORS_ORIGINS=http://localhost:3000

# Frontend (Vite build args)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ironden
VITE_KEYCLOAK_CLIENT_ID=ironden-app
VITE_API_URL=http://localhost:8000
